{
  "uid": "green-observatory-rt",
  "title": "Green Observatory \u2014 Real-time Energy & Carbon",
  "tags": [
    "green-observatory",
    "kepler",
    "carbon",
    "cern",
    "sustainability"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data source",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Node",
        "query": "label_values(kepler_node_cpu_watts, node_name)",
        "regex": "/.*baremetal.*/",
        "current": {},
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "zone",
        "type": "custom",
        "label": "RAPL zone",
        "query": "package,core",
        "current": {
          "text": "package",
          "value": "package"
        },
        "options": [
          {
            "text": "package",
            "value": "package",
            "selected": true
          },
          {
            "text": "core",
            "value": "core",
            "selected": false
          }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Namespace",
        "query": "label_values(kepler_pod_cpu_watts, pod_namespace)",
        "current": {
          "text": "green-experiment",
          "value": "green-experiment"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Pod",
        "query": "label_values(kepler_pod_cpu_watts{pod_namespace=~\"$namespace\"}, pod_name)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Node \u2014 baremetal (real-time)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total CPU power",
      "description": "RAPL package-domain power for the whole node (active + idle).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kepler_node_cpu_watts{node_name=~\"$node\",zone=\"$zone\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active CPU power",
      "description": "Dynamic power attributable to running work.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kepler_node_cpu_active_watts{node_name=~\"$node\",zone=\"$zone\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Idle CPU power",
      "description": "Static/idle draw of the RAPL domain.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kepler_node_cpu_idle_watts{node_name=~\"$node\",zone=\"$zone\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "CPU utilization",
      "description": "Node CPU busy ratio as reported by Kepler.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kepler_node_cpu_usage_ratio{node_name=~\"$node\"}*100",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Live grid intensity",
      "description": "RTE/eCO2mix production-based carbon intensity (gCO2eq/kWh). Requires the rte-carbon-exporter; shows No data otherwise.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(rte_carbon_intensity_gco2eq_per_kwh)",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 150
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Node emission rate",
      "description": "Operational CO2 rate = active watts x live intensity / 1000 (gCO2eq/h). Requires the exporter.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kepler_node_cpu_active_watts{node_name=~\"$node\",zone=\"$zone\"})*max(rte_carbon_intensity_gco2eq_per_kwh)/1000",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 150
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Total CO\u2082 \u2014 what Kubernetes is emitting (real-time)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "panels": []
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Node CO\u2082 rate (total)",
      "description": "Whole-node CPU emission rate now, gCO2eq/h = node package watts \u00d7 live RTE intensity. From recording rule node_co2_emission_gco2_per_second.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(node_co2_emission_gco2_per_second{node_name=~\"$node\",zone=\"$zone\"})*3600",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Workload CO\u2082 rate (active)",
      "description": "Emission rate attributable to running work (active watts) now, gCO2eq/h.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(node_co2_emission_active_gco2_per_second{node_name=~\"$node\",zone=\"$zone\"})*3600",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Cumulative CO\u2082 (range, total)",
      "description": "Node CPU CO2 accumulated over the selected range (gCO2eq). Per-interval weighted via the recording rule (Riemann sum, 15s = eval interval). Live approximation; greenctl jobs is authoritative per Job.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(sum_over_time(node_co2_emission_gco2_per_second{node_name=~\"$node\",zone=\"$zone\"}[$__range:15s]))*15",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Cumulative CO\u2082 (range, workload)",
      "description": "Active/workload CO2 accumulated over the range (gCO2eq).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(sum_over_time(node_co2_emission_active_gco2_per_second{node_name=~\"$node\",zone=\"$zone\"}[$__range:15s]))*15",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "CO\u2082 emission rate",
      "description": "gCO2eq/h over time. Needs the recording rules + RTE exporter.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(node_co2_emission_gco2_per_second{node_name=~\"$node\",zone=\"$zone\"})*3600",
          "legendFormat": "node total",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "refId": "B",
          "expr": "sum(node_co2_emission_active_gco2_per_second{node_name=~\"$node\",zone=\"$zone\"})*3600",
          "legendFormat": "workload (active)",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": ""
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Cumulative CO\u2082 by pod (range, gCO2eq)",
      "description": "Per-pod CO2 accumulated over the range from the recording rule (Riemann sum).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true,
          "expr": "topk(10, sum by (pod_name)(sum_over_time(pod_co2_emission_gco2_per_second{pod_namespace=~\"$namespace\",pod_name=~\"$pod\"}[$__range:15s])*15))",
          "legendFormat": "{{pod_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 15,
      "type": "row",
      "title": "Power & carbon over time",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "panels": []
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Node CPU power (package)",
      "description": "Total vs active vs idle package power.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kepler_node_cpu_watts{node_name=~\"$node\",zone=\"$zone\"})",
          "legendFormat": "total",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "refId": "B",
          "expr": "sum(kepler_node_cpu_active_watts{node_name=~\"$node\",zone=\"$zone\"})",
          "legendFormat": "active",
          "datasource": {
