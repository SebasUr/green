{
  "uid": "green-obs-job-drill",
  "title": "Green Observatory \u2014 Job drilldown",
  "tags": [
    "green-observatory",
    "kepler",
    "carbon",
    "jobs",
    "cern"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "title": "Back to Jobs",
      "tags": [
        "jobs"
      ],
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data source",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Namespace",
        "query": "label_values(kube_job_info, namespace)",
        "current": {
          "text": "green-experiment",
          "value": "green-experiment"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Job",
        "query": "label_values(kube_job_info{namespace=~\"$namespace\"}, job_name)",
        "current": {},
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Job $job \u2014 energy & CO\u2082 (exploration)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Energy (range)",
      "description": "Kepler pod CPU energy accumulated over the selected range. Authoritative value: greenctl jobs report.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max without(state)(increase(kepler_pod_cpu_joules_total{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\",zone=\"package\"}[$__range])))/3600000",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 6,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Average power (range)",
      "description": "Range energy / range duration. Meaningful when the range is the Job window.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max without(state)(increase(kepler_pod_cpu_joules_total{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\",zone=\"package\"}[$__range])))/3600000 * 3600000 / ($__range_s)",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cumulative CO\u2082 (range)",
      "description": "gCO2eq accumulated over the range, per-interval weighted via the pod_co2_emission recording rule (Riemann, 15s).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum_over_time(sum(pod_co2_emission_gco2_per_second{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\"})[$__range:15s])*15",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Peak power (range)",
      "description": "Highest attributed pod power seen in the range.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time((sum(max without(state)(kepler_pod_cpu_watts{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\",zone=\"package\"})))[$__range:15s])",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pod CPU power",
      "description": "Kepler-attributed CPU power for this Job's pod(s).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max without(state)(kepler_pod_cpu_watts{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\",zone=\"package\"}))",
          "legendFormat": "$job",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pod CO\u2082 emission rate",
      "description": "gCO2eq/h = pod watts \u00d7 live RTE intensity. Needs the recording rules + rte-carbon-exporter.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pod_co2_emission_gco2_per_second{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\"}) * 3600",
          "legendFormat": "$job",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cumulative energy (Kepler counter)",
      "description": "The raw cumulative Kepler counter in kWh \u2014 should rise monotonically while the pod runs and flatten when it ends.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max without(state)(kepler_pod_cpu_joules_total{pod_namespace=~\"$namespace\",pod_name=~\"$job-.*\",zone=\"package\"}))/3600000",
          "legendFormat": "$job",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Grid carbon intensity during the run",
      "description": "What the grid was doing while this Job ran.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(rte_carbon_intensity_gco2eq_per_kwh)",
          "legendFormat": "RTE FR gCO2eq/kWh",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 10,
      "type": "text",
      "title": "Provenance",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "options": {
        "mode": "markdown",
        "content": "These panels are **recomputed from Prometheus** (Kepler + RTE exporter) and are meant for exploring the shape of a run.\n\nThe **authoritative** energy and carbon for this Job \u2014 pod-precise boundaries, reset-aware counter deltas, per-interval RTE weighting and quality gates \u2014 comes from:\n\n```bash\ngreenctl jobs report $job -n $namespace --output runs/job-reports\n```\nIf a number here disagrees with the JSON report, the report wins."
      }
    }
  ]
}
